{
  "editor.tabSize": 2,
  "editor.indentSize": "tabSize",
  "markdownlint.config": {
    "MD001": false,
    "MD033": false,
    "MD034": false,
    "MD036": false,
    "MD041": false
  },
  "cSpell.words": [
    "bufpool",
    "Inno",
    "memcmp",
    "memcmpable",
    "Memcomparable",
    "minesql",
    "RDBMS",
    "slottedpage",
    "Varchar"
  ],
  "go.lintTool": "golangci-lint-v2",
  "go.lintFlags": ["--path-mode=abs", "--fast-only"],
  "go.formatTool": "custom",
  "go.alternateTools": {
    "customFormatter": "golangci-lint-v2"
  },
  "go.formatFlags": ["fmt", "--stdin"]
}
